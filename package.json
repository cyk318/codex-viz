{
  "name": "codex-viz",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tailwindcss -i ./src/tailwind.input.css -o ./src/generated.css && bun --hot server.ts",
    "start": "tailwindcss -i ./src/tailwind.input.css -o ./src/generated.css && bun server.ts",
    "start:bg": "bash scripts/start-background.sh",
    "stop:bg": "bash scripts/stop-background.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.0",
    "@xyflow/react": "^12.3.0",
    "dagre": "^0.8.5",
    "react": "^18.3.0",
    "react-diff-viewer-continued": "^4.0.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dagre": "^0.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
